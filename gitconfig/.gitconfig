[user]
  name = link1183
  email = adrien.gunther@gmail.com
  signingkey = /home/agunthe1/.ssh/id_ed25519

[includeIf "gitdir:/home/agunthe1/projects/github/"]
  path = .gitconfig-github

[includeIf "gitdir:/home/agunthe1/projects/gitlab/"]
  path = /home/agunthe1/.gitconfig-gitlab

[core]
  pager = diff-so-fancy | less --tabs=4 -RF
	autocrlf = input
[interactive]
  diffFilter = diff-so-fancy --patch
[color]
  ui = true
[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22
[color "diff"]
  meta = 11
  frag = magenta bold
  func = 146 bold
  commit = yellow bold
  old = red bold
  new = green bold
  whitespace = red reverse
[diff-so-fancy]
  changeHunkIndicators = false
  stripLeadingSymbols = false
  useUnicodeRuler = false
  rulerWidth = 80
[rerere]
  enabled = true
[column]
  ui = auto
[init]
  defaultbranch = main
[pull]
  rebase = true
